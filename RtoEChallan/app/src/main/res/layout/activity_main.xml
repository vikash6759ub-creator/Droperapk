<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp">
            <ImageView
                android:id="@+id/play_logo"
                android:layout_width="140dp"
                android:layout_height="40dp"
                android:src="@drawable/google_play_text_logo" 
                android:scaleType="fitStart"/>
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_alignParentEnd="true"
                android:layout_centerInParent="true"
                android:src="@android:drawable/ic_menu_search"
                app:tint="#5F6368" />
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <androidx.cardview.widget.CardView
                android:layout_width="85dp"
                android:layout_height="85dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="2dp">
                <ImageView
                    android:id="@+id/app_logo"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerInside"
                    android:padding="10dp"/>
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="20dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RTO Challan"
                    android:textSize="22sp"
                    android:textColor="#202124"
                    android:fontFamily="sans-serif-medium" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="National Informatics Centre."
                    android:textColor="#01875f"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Verified by Play Protect"
                    android:textSize="12sp"
                    android:layout_marginTop="8dp"
                    android:textColor="#5F6368"
                    android:drawableStart="@android:drawable/checkbox_on_background"
                    android:drawablePadding="4dp"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="25dp"
            android:gravity="center">
            
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView android:text="4.2 ★" android:textColor="#202124" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:text="8L reviews" android:textSize="10sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
            <View android:layout_width="1dp" android:layout_height="25dp" android:background="#E0E0E0"/>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView android:text="12 MB" android:textColor="#202124" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:text="Size" android:textSize="10sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
            <View android:layout_width="1dp" android:layout_height="25dp" android:background="#E0E0E0"/>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView android:text="10M+" android:textColor="#202124" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:text="Downloads" android:textSize="10sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="25dp">
            <Button
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="48dp"
                android:text="Uninstall"
                android:textColor="#01875f"
                android:backgroundTint="#FFFFFF"
                android:layout_marginEnd="10dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
            <Button
                android:id="@+id/btnInstall"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="48dp"
                android:text="Update"
                android:backgroundTint="#01875f"
                android:textColor="#FFFFFF"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ratings and reviews"
            android:textSize="18sp"
            android:textColor="#202124"
            android:layout_marginTop="30dp"
            android:fontFamily="sans-serif-medium" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginTop="15dp">
            <TextView android:text="V Vikash Kumar" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:text="★★★★★ 16/03/26" android:textSize="11sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:text="Finally problem solved! After update, my challan details are showing correctly." android:layout_marginTop="5dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#5F6368"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginTop="15dp">
            <TextView android:text="R Rahul Sharma" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:text="★★★★★ 15/03/26" android:textSize="11sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:text="Very fast and clean interface. Good job developers." android:layout_marginTop="5dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#5F6368"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
